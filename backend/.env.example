# MongoDB Database Connection
MONGODB_URL="mongodb+srv://<your-username>:<your-password>@cluster.mongodb.net/expense-ai?retryWrites=true&w=majority"

# Security (Generate a strong random string for production)
SECRET_KEY="your-super-secret-key-for-jwt"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Gemini AI (Optional, for AI insights)
GEMINI_API_KEY="your-gemini-api-key"

# Email Verification (Optional, for sending real verification codes)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
